  <text x="185" y="120" font-size="9" fill="currentColor" text-anchor="middle">yunque</text>

  <!-- Estribo -->
  <line x1="210" y1="140" x2="265" y2="160" stroke="currentColor" stroke-width="2.5"/>
  <circle cx="265" cy="160" r="5" fill="currentColor"/>
  <!-- Platina del estribo -->
  <rect x="268" y="150" width="8" height="20" fill="currentColor" opacity="0.7"/>
  <text x="265" y="143" font-size="9" fill="currentColor" text-anchor="middle">estribo</text>

  <!-- Ventana oval -->
