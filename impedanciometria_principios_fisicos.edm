  <circle cx="205" cy="210" r="2.5" fill="currentColor" opacity="0.4"/>
  <circle cx="218" cy="198" r="2.5" fill="currentColor" opacity="0.4"/>
  <circle cx="200" cy="202" r="2.5" fill="currentColor" opacity="0.4"/>
