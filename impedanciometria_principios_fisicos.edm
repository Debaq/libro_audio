  <text x="30"  y="18"  font-size="10" fill="currentColor">P</text>

  <!-- Línea de referencia P=0 del canal -->
  <line x1="50" y1="140" x2="510" y2="140" stroke="currentColor" stroke-width="1" stroke-dasharray="4,4" opacity="0.3"/>
  <text x="52" y="136" font-size="8" fill="currentColor" opacity="0.5">P ref</text>

  <!-- Curva de barrido de presión (lenta, de +200 a -400 daPa) -->
  <path d="M60,80 C120,82 180,88 240,120 C300,152 360,175 420,185 C460,190 490,192 505,193"
        stroke="currentColor" stroke-width="2.5" fill="none" stroke-dasharray="8,3"/>

  <!-- Tono sonda superpuesto (oscilación rápida pequeña sobre la curva de barrido) -->
  <!-- Segmento inicial (P alta, membrana tensa) — amplitud pequeña -->
  <path d="M60,80 C63,72 66,88 69,80 C72,72 75,88 78,80 C81,72 84,88 87,80 C90,72 93,88 96,80 C99,72 102,88 105,80 C108,72 111,88 114,82 C117,74 120,90 123,82"
        stroke="currentColor" stroke-width="1.2" fill="none"/>

  <!-- Segmento medio (presión neutra, membrana libre) — amplitud máxima -->
  <path d="M228,120 C231,104 234,136 237,120 C240,104 243,136 246,120 C249,104 252,136 255,120 C258,104 261,136 264,120 C267,104 270,136 273,120 C276,104 279,136 282,120"
        stroke="currentColor" stroke-width="1.2" fill="none"/>

  <!-- Segmento final (P baja, membrana tensa opuesta) — amplitud pequeña de nuevo -->
  <path d="M408,185 C411,179 414,191 417,185 C420,179 423,191 426,185 C429,179 432,191 435,185 C438,179 441,191 444,185 C447,179 450,191 453,185"
        stroke="currentColor" stroke-width="1.2" fill="none"/>

  <!-- Anotaciones -->
  <text x="80"  y="58"  font-size="10" fill="currentColor">presión alta (+200 daPa)</text>
  <text x="80"  y="70"  font-size="9"  fill="currentColor" opacity="0.7">membrana tensa → respuesta pequeña</text>

  <text x="220" y="100" font-size="10" fill="currentColor">presión neutra (0 daPa)</text>
  <text x="220" y="112" font-size="9"  fill="currentColor" opacity="0.7">membrana libre → respuesta máxima</text>

  <text x="380" y="168" font-size="10" fill="currentColor">presión baja (−400 daPa)</text>
  <text x="380" y="180" font-size="9"  fill="currentColor" opacity="0.7">membrana tensa → respuesta pequeña</text>

