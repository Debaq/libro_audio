  <!-- Compresión 1 cerca de x=95 -->
  <circle cx="82" cy="105" r="2.5" fill="currentColor" opacity="0.8"/>
  <circle cx="90" cy="98"  r="2.5" fill="currentColor" opacity="0.8"/>
  <circle cx="98" cy="102" r="2.5" fill="currentColor" opacity="0.8"/>
