  <text x="52" y="226" font-size="8" fill="currentColor" opacity="0.5">resonancia</text>

  <!-- PUNTO 1: Oído normal -->
  <line x1="230" y1="230" x2="320" y2="140" stroke="currentColor" stroke-width="2" marker-end="url(#apv)" stroke-dasharray="5,3"/>
